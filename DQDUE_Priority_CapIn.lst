 226   
 227  eq_mu(i, j, r)$(ord(r)>=nh(i,j)+1 and links(i,j) and not dummydesti(j))..
 228  (sum(s$(ord(s)>=nh(i,j)+1 and (ord(s)<=ord(r))),p(i,j,s-nh(i,j))-Cbar(i,j)+mu(i,j,s)+deltabar(i,j,s)))*hlength =g= 0;
 229   
 230  eq_p(i, j, r-nh(i,j))$(ord(r)>=nh(i,j)+1 and links(i,j) and not dummydesti(j))..
 231  *(1+sigma(i,j,r))*(tao0(i,j)+(hlength/Cbar(i,j))*sum(s$(ord(s)>=nh(i,j)+1 and ord(s)<=ord(r)),p(i,j,s-nh(i,j))-Cbar(i,j)+mu(i,j,s)+deltabar(i,j,s))) + pi(j, r)- pi(i, r-nh(i,j)) -sigma(i,j,r)*tao0(i,j) =g= 0;
 232  (1+sigma(i,j,r))*(tao0(i,j)+(1+(mu(i,j,r)+deltabar(i,j,r))/Cbar(i,j))*(hlength/Cbar(i,j))*sum(s$(ord(s)>=nh(i,j)+1 and ord(s)<=ord(r)),p(i,j,s-nh(i,j))-Cbar(i,j)+mu(i,j,s)+deltabar(i,j,s))) + pi(j, r)- pi(i, r-nh(i,j)) -sigma(i,j,r)*tao0(i,j) =g= 0;
 233   
 234  eq_pi(i, r)$(ord(r)<=card(h)-1-nhead(i)+1 and (not desti(i)) and not dummydesti(i))..
 235  sum(j$(links(i,j) and ord(r)<=card(h)-1+1-nh(i,j)),p(i,j,r)) - sum(j$(links(j,i) and ord(r)>=nh(j,i)+1),Cbar(j,i)-mu(j,i,r)-deltabar(j,i,r)) - d(i,r) =g= 0;
 236   
 237  eq_deltabar(i,j,r)$(links(i,j) and ord(r)>=nh(i,j)+1 and not dummydesti(j))..
 238  sum(k$links(j,k), eta(j,k,r)+etap(j,k,r)) + sum(k$links(j,k), etadesti(j,k,r)) - sum(l$(ord(l)<ord(i)), deltah(l,j,r)) - deltabar(i,j,r) =g= 0;
 239   
 240  eq_v(i,j,r)$(links(i,j) and ord(r)>=nh(i,j)+1 and not dummydesti(j))..
 241  deltabar(i,j,r) =e= Cbar(i,j) - mu(i,j,r) - v(i,j,r);
 242   
 243  eq_delta(i,j,r)$(links(i,j) and ord(r)>=nh(i,j)+1 and not dummydesti(j))..
 244  deltah(i,j,r) - deltabar(i,j,r) =g= 0;
 245  *deltah(i, j, r) =e= ((Cbar(i,j)-mu(i,j,r))/(epsilon+sum(l$links(l,j), Cbar(l,j)-mu(l,j,r))) * sum(k$links(j,k), eta(j,k,r)))$(sum(l$links(l,j),1)>1) + sum(k$links(j,k), epsilon4*eta(j,k,r))$(sum(l$links(l,j),1)<=1);
 246  *deltah(i, j, r) =e= (Cbar(i,j)-mu(i,j,r))/(epsilon+sum(l$links(l,j), Cbar(l,j)-mu(l,j,r))) * sum(k$links(j,k), eta(j,k,r));
 247   
 248  eq_etap(i, j, r)$(links(i,j) and (not dummyori(i)) and (ord(r)>=nbeforehead(i)+1) and not dummydesti(j))..
 249  1*Cbar(i,j) - p(i,j,r) =g= 0;
 250   
 251  eq_eta(i, j, r)$(links(i,j) and (not dummyori(i)) and (ord(r)>=nbeforehead(i)+1))..
 252  Qbar(i,j) - hlength*sum(s$(ord(s)<nomegah(i,j)+1 and ord(s)<=ord(r)), p(i,j,s)) - hlength* sum(s$(ord(s)>=nomegah(i,j)+1 and ord(s)<=ord(r)), p(i,j,s)-Cbar(i,j)+mu(i,j,s-nomegah(i,j))+deltabar(i,j,s-nomegah(i,j))) =g= 0;
 253   
 254  *Effectively eta=0 for dummy destination link, since Qbar->inf
 255  eq_eta_desti(i, j, r)$(links(i,j) and dummydesti(j) and (ord(r)>=nbeforehead(i)+1))..
 256  Qbar(i,j) - hlength*sum(s$(ord(s)<=ord(r)), sum(l$(links(l,i)),v(l,i,s)) ) =g= 0;
