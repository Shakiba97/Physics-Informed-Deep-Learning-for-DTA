 260   
 261  eq_zeta0(i, r)$(ord(r)<=card(h)-1-nhead(i)+1 and (not desti(i)) and dummyori(i))..
 262  -(Delta+hlength*ord(r)-R_para(i))-pi(i,r)+zeta0(i,r)+zetap(i,r) =g= 0;
 263   
 264  eq_zetap(i, r)$(ord(r)<=card(h)-1-nhead(i)+1 and (not desti(i)) and dummyori(i))..
 265  2*Delta - zeta0(i,r) =g= 0;
 266   
